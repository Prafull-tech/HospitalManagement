# Copy to .env.local for local overrides (not committed).

# Optional: if the API is not same-origin, set the full API origin (must end without /api if client still uses /api paths).
# VITE_API_BASE_URL=http://localhost:8080

# Tenant-domain settings. Recommended split:
# - development: .hms.local
# - production: .hms.com
# VITE_TENANT_BASE_DOMAIN=.hms.local
# VITE_PLATFORM_HOSTS=hms.local,admin.hms.local
# VITE_ALLOWED_HOSTS=.hms.local,localhost,127.0.0.1

# In production builds, stub sidebar entries (Radiology, HR, Enquiry, Visitor) are hidden by default.
# Set to true to show them (e.g. demos).
# VITE_SHOW_STUB_SIDEBAR=true
