# Copy this file to application-local.yml (gitignored) and fill in your local values.
# This file is imported automatically by application.yml via spring.config.import.

spring:
  datasource:
    username: root
    password: your-local-mysql-password

hms:
  tenant:
    base-domain: hms.local
  security:
    jwt:
      expiry-minutes: 30
    cors:
      allowed-origin-patterns: "http://localhost:*,http://127.0.0.1:*,http://192.168.*:*,http://*.hms.local:*"

# Uncomment to override JWT secret locally
# hms:
#   security:
#     jwt:
#       secret: my-local-dev-secret
